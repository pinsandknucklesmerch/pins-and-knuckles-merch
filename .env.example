# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Server-only Supabase service-role key used for privileged team provisioning. Never use NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only Monday.com token for read-only historical KPI discovery. Never use NEXT_PUBLIC_.
MONDAY_API_TOKEN=your-monday-api-token
# Optional: set only after board discovery confirms the mapping.
MONDAY_SALES_BOARD_ID=
MONDAY_QUOTES_BOARD_ID=
MONDAY_ORDERS_BOARD_ID=

# Server-only Google OAuth credentials for the Gmail EPCC profit importer.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_REPORT_ADDRESS=

# Server-only bearer secret used by Vercel Cron.
CRON_SECRET=
